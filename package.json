{
  "name": "medialayers",
  "version": "1.0.2",
  "description": "Software de apresentação com camadas de mídia para igrejas e eventos",
  "author": "MediaLayers Team",
  "license": "MIT",
  "homepage": "https://github.com/Alexandre-Gervasio/medialayers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alexandre-Gervasio/medialayers.git"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "webrtc-server": "node webrtc-server.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win nsis",
    "build:win:publish": "electron-builder --win nsis --publish always",
    "build:win:docker": "bash ./scripts/build-win-docker.sh",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:win": "electron-rebuild -f -w better-sqlite3 --arch=x64",
    "ci:smoke": "node ./scripts/ci-smoke.js",
    "release:check": "node ./scripts/release-check.js"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.medialayers.app",
    "productName": "MediaLayers",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg.exe",
        "to": "ffmpeg.exe"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Alexandre-Gervasio",
      "repo": "medialayers",
      "releaseType": "release"
    }
  }
}
