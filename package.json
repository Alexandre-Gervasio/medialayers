{
  "name": "medialayers",
  "version": "1.0.0",
  "description": "Software de apresentação com camadas de mídia para igrejas e eventos",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "webrtc-server": "node webrtc-server.js",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^5.2.1",
    "golden-layout": "^2.6.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.medialayers.app",
    "productName": "MediaLayers",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg.exe",
        "to": "ffmpeg.exe"
      }
    ]
  }
}
